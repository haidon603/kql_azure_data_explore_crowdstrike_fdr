 
//IDP uses network traffic while the event DCSyncAttempted uses ETW. This is why IDP DCSync detections do not have a corresponding DCSyncAttempted log in FDR.
//To investigate IDP DCSync detections (or examine DC Syncing in general from non DC sources), you can search for ActiveDirectoryIncomingDceRpcRequest  RpcOpClassification == "1",
 
//DCSyncAttempted - Directory Services changes were replicated. If the source host is not a Domain Controller, this could represent malicious activity.
CrowdStrikeFDR
| where TimeGenerated >= ago(1d)
| where event_simpleName == 'DCSyncAttempted'
| project TimeGenerated, ComputerName, OU, ClientComputerName, UserName, SubjectDomainNameEtw, MachineDomain, cid, record
 
//ActiveDirectoryIncomingDceRpcRequest - Indicates that the Domain Controller must handle one or more incoming DCE/RPC requests from an account on an endpoint.
CrowdStrikeFDR
| where TimeGenerated >= ago(1d)
| where event_simpleName == 'ActiveDirectoryIncomingDceRpcRequest'
| extend RpcOpClassification = case(
                                   RpcOpClassification == "1",
                                   "DC_SYNC",
                                   RpcOpClassification == "2",
                                   "SPN_MODIFICATION",
                                   RpcOpClassification == "3",
                                   "REPLICATION_SERVER_REGISTRATION",
                                   RpcOpClassification == "4",
