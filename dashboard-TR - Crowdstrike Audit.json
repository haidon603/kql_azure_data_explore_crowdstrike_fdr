9b76cb24","usedVariables":["_endTime","_startTime","user_t"]},{"dataSource":{"kind":"inline","dataSourceId":"446b5fb7-9871-40fd-9f4e-7e7a433851cb"},"text":"CrowdStrikeFDR\n| where TimeGenerated between (_startTime.._endTime)  \n| where ServiceName == \"Crowdstrike API Client\" \n| where UserId has_any (user_t)\n| where isnotempty(UserId)\n| project EventType, OperationName,Success, ServiceName, UserId, UserIp, TimeGenerated, AuditKeyValues, cid, record","id":"3437d5a0-2ead-4876-8659-5e24c5be4745","usedVariables":["_endTime","_startTime","user_t"]},{"dataSource":{"kind":"inline","dataSourceId":"446b5fb7-9871-40fd-9f4e-7e7a433851cb"},"text":"CrowdStrikeFalcon\n| where TimeGenerated between (_startTime.._endTime)  \n| where cat == \"RemoteResponseSessionEndEvent\"\n| extend Commands = parse_json(record).cmd, FalconUser = parse_json(record).duser, RTRHost = parse_json(record).dhost\n| where  FalconUser has_any (user_t)\n| project TimeGenerated, FalconUser, RTRHost, Commands\n| sort by tostring(FalconUser), tostring(RTRHost), tostring(TimeGenerated)","id":"e0da2072-2b29-41e8-b594-69cd031b9bda","usedVariables":["_endTime","_startTime","user_t"]},{"dataSource":{"kind":"inline","dataSourceId":"446b5fb7-9871-40fd-9f4e-7e7a433851cb"},"text":"CrowdStrikeFDR\n| where TimeGenerated between (_startTime.._endTime)   //| search \"haidon\"\n//| summarize count() by event_simpleName// \n| where event_simpleName  has \"UserActivityAuditEvent\" or record has  'Event_ExternalApiEvent' \n| summarize by OperationName","id":"8d4aa78d-7c6f-4a25-af52-26afe168094d","usedVariables":["_endTime","_startTime"]},{"dataSource":{"kind":"inline","dataSourceId":"446b5fb7-9871-40fd-9f4e-7e7a433851cb"},"text":"CrowdStrikeFDR\n| where TimeGenerated between (_startTime.._endTime)   //| search \"haidon\"\n//| summarize count() by event_simpleName// \n| where event_simpleName  has \"UserActivityAuditEvent\" or record has  'Event_ExternalApiEvent' \n| summarize by UserId","id":"340e3347-27ae-4e0f-9c42-2e946d